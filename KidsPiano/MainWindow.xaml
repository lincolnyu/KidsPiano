<Window x:Class="KidsPiano.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Kids Piano 🎹"
        WindowState="Maximized"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FF4A90E2"
        FontFamily="Segoe UI"
        FontSize="24">

    <Window.Resources>
        <!-- Shared big rounded button style -->
        <Style TargetType="Button">
            <Setter Property="Background"   Value="#FF7CB9E8"/>
            <Setter Property="Foreground"   Value="White"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="BorderBrush"  Value="Transparent"/>
            <Setter Property="Cursor"       Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14" Padding="6,4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground"  Value="#222"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Row 0: File & Song -->
            <RowDefinition Height="Auto"/> <!-- Row 1: Controls   -->
            <RowDefinition Height="2*"/>   <!-- Row 2: Score      -->
            <RowDefinition Height="*"/>    <!-- Row 3: Keyboard   -->
        </Grid.RowDefinitions>

        <!-- ═══════════════ ROW 0: File & Song Name ═══════════════ -->
        <Border Grid.Row="0" Margin="16,10,16,4" Background="#FF81C784"
                CornerRadius="20" Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="btnOpen" Content="📂 Open File"
                        Width="200" Height="60"
                        Background="#FFFFD700" Foreground="#333"
                        FontSize="24" FontWeight="Bold"
                        Click="btnOpen_Click"/>

                <TextBlock x:Name="txtSongName" Margin="30,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="30" FontWeight="Bold" Foreground="White"
                           Text="Untitled piece"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════ ROW 1: Controls ═══════════════ -->
        <Border Grid.Row="1" Margin="16,4,16,4" Background="#FFFFB74D"
                CornerRadius="20" Padding="16,8">
            <WrapPanel Orientation="Horizontal">

                <!-- Mode -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Mode" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbMode" Width="200" Height="50" FontSize="22"
                              SelectionChanged="cmbMode_SelectionChanged">
                        <ComboBoxItem Content="🎵 App-led"     IsSelected="True"/>
                        <ComboBoxItem Content="🎹 Player-led"/>
                    </ComboBox>
                </StackPanel>

                <!-- Speed -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Speed" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="btnSpeed01" Content="0.1x" Width="68" Height="50" Tag="0.1" 
                                Click="SpeedButton_Click" Margin="2" FontSize="20"/>
                        <Button x:Name="btnSpeed025" Content="0.25x" Width="72" Height="50" Tag="0.25" 
                                Click="SpeedButton_Click" Margin="2" FontSize="20"/>
                        <Button x:Name="btnSpeed05" Content="0.5x" Width="68" Height="50" Tag="0.5" 
                                Click="SpeedButton_Click" Margin="2" FontSize="20"/>
                        <Button x:Name="btnSpeed1x" Content="1x" Width="60" Height="50" Tag="1.0"
                                Click="SpeedButton_Click" Margin="2" FontSize="20"/>
                    </StackPanel>
                </StackPanel>

                <!-- Transport -->
                <StackPanel Margin="16,4,8,4" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnRestart"   Content="🔄"   Width="60"  Height="60" Click="btnRestart_Click"   Margin="3" FontSize="26"/>
                    <Button x:Name="btnPrev"       Content="⏮"   Width="60"  Height="60" Click="btnPrev_Click"      Margin="3" FontSize="26"/>
                    <Button x:Name="btnPlayPause"  Content="▶"   Width="80"  Height="60"
                            Background="#FF4CAF50" Click="btnPlayPause_Click" Margin="3" FontSize="26"/>
                    <Button x:Name="btnNext"       Content="⏭"   Width="60"  Height="60" Click="btnNext_Click"      Margin="3" FontSize="26"/>
                </StackPanel>

                <!-- Playback Volume -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Volume" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <Slider x:Name="sldVolume" Width="150" Minimum="0" Maximum="100" Value="80"
                            Height="50" VerticalAlignment="Center"
                            ValueChanged="sldVolume_ValueChanged"/>
                </StackPanel>

                <!-- Metronome -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Metronome" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <Slider x:Name="sldMetronome" Width="130" Minimum="0" Maximum="100" Value="50"
                            Height="50" VerticalAlignment="Center"
                            ValueChanged="sldMetronome_ValueChanged"/>
                </StackPanel>

                <!-- Tolerance -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Tolerance" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbTolerance" Width="190" Height="50" FontSize="22"
                              SelectionChanged="cmbTolerance_SelectionChanged">
                        <ComboBoxItem Content="🎯 Strict"      IsSelected="True"/>
                        <ComboBoxItem Content="😊 Medium"/>
                        <ComboBoxItem Content="😄 Easy"/>
                    </ComboBox>
                </StackPanel>

                <!-- Wrong Notes -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Wrong Notes" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbWrongHandling" Width="210" Height="50" FontSize="22"
                              SelectionChanged="cmbWrongHandling_SelectionChanged">
                        <ComboBoxItem Content="⏳ Wait" IsSelected="True"/>
                        <ComboBoxItem Content="🔁 Repeat"/>
                    </ComboBox>
                </StackPanel>

                <!-- Keyboard Zoom -->
                <StackPanel Margin="8,4">
                    <TextBlock Text="Keyboard" FontSize="18" Foreground="White" Margin="0,0,0,4"/>
                    <ComboBox x:Name="cmbZoom" Width="160" Height="50" FontSize="22"
                              SelectionChanged="cmbZoom_SelectionChanged">
                        <ComboBoxItem Content="1 Octave"      Tag="1"/>
                        <ComboBoxItem Content="2 Octaves"     Tag="2"/>
                        <ComboBoxItem Content="3 Octaves"     Tag="3" IsSelected="True"/>
                        <ComboBoxItem Content="4 Octaves"     Tag="4"/>
                        <ComboBoxItem Content="Full 88"       Tag="88"/>
                    </ComboBox>
                </StackPanel>

                <!-- Non-piano toggle -->
                <CheckBox x:Name="chkNonPiano" Content="🎻 Non-piano parts"
                          Margin="20,40,0,0" FontSize="22" Foreground="White"
                          VerticalAlignment="Center"/>

                <!-- Mic button -->
                <Button x:Name="btnMicToggle" Content="🎤 Mic Off"
                        Width="140" Height="50" Margin="12,10"
                        Click="btnMicToggle_Click" FontSize="20"/>

            </WrapPanel>
        </Border>

        <!-- ═══════════════ ROW 2: Score (OSMD WebView2) ═══════════════ -->
        <wpf:WebView2 x:Name="webViewScore" Grid.Row="2"
                      Margin="16,4" DefaultBackgroundColor="White"/>

        <!-- ═══════════════ ROW 3: Keyboard ═══════════════ -->
        <Border Grid.Row="3" Margin="16,4,16,10" Background="#FF2E7D32"
                CornerRadius="20" Padding="14">
            <Canvas x:Name="canvasKeyboard"
                    Background="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>
        </Border>
    </Grid>
</Window>
