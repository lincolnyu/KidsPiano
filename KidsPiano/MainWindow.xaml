<Window x:Class="KidsPiano.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wpf="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Kids Piano 🎹" 
        WindowState="Maximized"
        ResizeMode="NoResize"
        WindowStyle="None"
        Background="#FF4A90E2"
        FontFamily="Segoe UI"
        FontSize="24">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Row 0: File & Song -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Controls -->
            <RowDefinition Height="*"/>
            <!-- Sheet Area (~2/3) -->
            <RowDefinition Height="2*"/>
            <!-- Keyboard Area (~1/3) -->
        </Grid.RowDefinitions>

        <!-- ==================== ROW 0: File & Song Name ==================== -->
        <Border Grid.Row="0" Margin="20" Background="#FF81C784" CornerRadius="20" Padding="20">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="btnOpen" Content="📂 Open MusicXML" 
                        Width="240" Height="70" 
                        Background="#FFFFD700" Foreground="Black" 
                        FontSize="26" FontWeight="Bold" Click="btnOpen_Click"/>

                <TextBlock x:Name="txtSongName" Margin="40,0,0,0" 
                           VerticalAlignment="Center" 
                           FontSize="32" FontWeight="Bold" Foreground="White" 
                           Text="Untitled piece"/>
            </StackPanel>
        </Border>

        <!-- ==================== ROW 1: All Controls ==================== -->
        <Border Grid.Row="1" Margin="20,10,20,20" Background="#FFFFB74D" CornerRadius="20" Padding="20">
            <WrapPanel Orientation="Horizontal">

                <!-- Mode -->
                <StackPanel Margin="12">
                    <TextBlock Text="Mode" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbMode" Width="180" Height="55" FontSize="24">
                        <ComboBoxItem Content="App-led (Listening)" IsSelected="True"/>
                        <ComboBoxItem Content="Player-led (Tracking)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Speed -->
                <StackPanel Margin="12">
                    <TextBlock Text="Speed" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="0.1x" Width="75" Height="55" Tag="0.1" Click="SpeedButton_Click" Margin="2"/>
                        <Button Content="0.25x" Width="75" Height="55" Tag="0.25" Click="SpeedButton_Click" Margin="2"/>
                        <Button Content="0.5x" Width="75" Height="55" Tag="0.5" Click="SpeedButton_Click" Margin="2"/>
                        <Button Content="1x" Width="75" Height="55" Tag="1.0" Click="SpeedButton_Click" 
                                Background="#FF4CAF50" Margin="2"/>
                    </StackPanel>
                </StackPanel>

                <!-- Playback Buttons -->
                <StackPanel Margin="25,12,12,12" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="btnRestart" Content="🔄 Restart" Width="120" Height="65" Click="btnRestart_Click" Margin="4"/>
                    <Button x:Name="btnPlayPause" Content="▶ Play" Width="120" Height="65" Margin="8,4" Click="btnPlayPause_Click"/>
                    <Button x:Name="btnNext" Content="⏭ Next" Width="100" Height="65" Click="btnNext_Click" Margin="4"/>
                    <Button x:Name="btnPrev" Content="⏮ Prev" Width="100" Height="65" Click="btnPrev_Click" Margin="4"/>
                </StackPanel>

                <!-- Volume -->
                <StackPanel Margin="12">
                    <TextBlock Text="Volume" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <Slider x:Name="sldVolume" Width="190" Minimum="0" Maximum="100" Value="80" TickFrequency="10" Height="55"/>
                </StackPanel>

                <!-- Metronome -->
                <StackPanel Margin="12">
                    <TextBlock Text="Metronome" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <Slider x:Name="sldMetronome" Width="160" Minimum="0" Maximum="100" Value="50" TickFrequency="10" Height="55"/>
                </StackPanel>

                <!-- Tolerance -->
                <StackPanel Margin="12">
                    <TextBlock Text="Tolerance" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbTolerance" Width="180" Height="55" FontSize="24">
                        <ComboBoxItem Content="Strict (All keys)" IsSelected="True"/>
                        <ComboBoxItem Content="Medium (2 keys)"/>
                        <ComboBoxItem Content="Easy (1 key)"/>
                    </ComboBox>
                </StackPanel>

                <!-- Wrong Notes Handling -->
                <StackPanel Margin="12">
                    <TextBlock Text="Wrong Notes" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbWrongHandling" Width="210" Height="55" FontSize="24">
                        <ComboBoxItem Content="Wait until correct" IsSelected="True"/>
                        <ComboBoxItem Content="Repeat segment"/>
                    </ComboBox>
                </StackPanel>

                <!-- Keyboard Zoom -->
                <StackPanel Margin="12">
                    <TextBlock Text="Keyboard Zoom" FontSize="20" Foreground="White" Margin="0,0,0,8"/>
                    <ComboBox x:Name="cmbZoom" Width="160" Height="55" FontSize="24" SelectionChanged="cmbZoom_SelectionChanged">
                        <ComboBoxItem Content="1 Octave" Tag="1"/>
                        <ComboBoxItem Content="2 Octaves" Tag="2"/>
                        <ComboBoxItem Content="3 Octaves" Tag="3" IsSelected="True"/>
                        <ComboBoxItem Content="4 Octaves" Tag="4"/>
                        <ComboBoxItem Content="Full (88 keys)" Tag="88"/>
                    </ComboBox>
                </StackPanel>

                <!-- Also play non-piano -->
                <CheckBox x:Name="chkNonPiano" Content="Also play non-piano part" 
                          Margin="30,35,0,0" FontSize="24" Foreground="White" VerticalAlignment="Center"/>

                <Button Content="🎤 Start Mic" Width="140" Height="55" Margin="12" Click="btnMicToggle_Click"/>
            </WrapPanel>
        </Border>

        <!-- ==================== Sheet Display ==================== -->
        <wpf:WebView2 x:Name="webViewScore" Grid.Row="2" Margin="20" DefaultBackgroundColor="White" />

        <!-- ==================== Keyboard ==================== -->
        <Border Grid.Row="3" Margin="20" Background="#FF2E7D32" CornerRadius="20" Padding="15">
            <Canvas x:Name="canvasKeyboard" 
                    Background="Transparent" 
                    HorizontalAlignment="Stretch" 
                    VerticalAlignment="Stretch" />
        </Border>
    </Grid>
</Window>